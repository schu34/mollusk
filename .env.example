# The ID of your GitHub App
APP_ID=
WEBHOOK_SECRET=development

# Use `trace` to get verbose logging or `info` to show less
LOG_LEVEL=debug

# Go to https://smee.io/new set this to the URL that you are redirected to.
WEBHOOK_PROXY_URL=

# The GitHub username of the bot account (used for @mention detection)
BOT_USERNAME=mollusk-agent

# Redis URL for BullMQ job queue
REDIS_URL=redis://localhost:6379

# Optional: base directory for agent workspaces (defaults to OS temp dir)
WORKSPACE_BASE_DIR=

# Optional: agent timeout in milliseconds (default: 900000 = 15 minutes)
AGENT_TIMEOUT=

# Anthropic API key for the Claude Agent SDK
ANTHROPIC_API_KEY=
